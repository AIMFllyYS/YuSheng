# Qiniu Cloud AI API Configuration
# Get your API key from https://qiniu.com/ai console
# Docs: https://developer.qiniu.com/aitokenapi/12884/how-to-get-api-key

# API Key (sk-xxxxx format)
QINIU_API_KEY=sk-your-api-key-here

# API Base URL (OpenAI-compatible endpoint)
QINIU_BASE_URL=https://api.qnaigc.com/v1

# Optional: Anthropic-compatible endpoint
ANTHROPIC_AUTH_TOKEN=sk-your-api-key-here
ANTHROPIC_BASE_URL=https://api.qnaigc.com
